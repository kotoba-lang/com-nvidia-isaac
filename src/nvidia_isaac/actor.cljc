;; collection → CRUD fns, keyed by the /v1/<collection> path segment
(def ^:private handlers
  {"simrobots" {:create create-sim-robot :list list-sim-robots :get get-sim-robot :update update-sim-robot :delete delete-sim-robot}
   "skills" {:create create-skill :list list-skills :get get-skill :update update-skill :delete delete-skill}
   "simscenes" {:create create-sim-scene :list list-sim-scenes :get get-sim-scene :update update-sim-scene :delete delete-sim-scene}
   "policies" {:create create-policy :list list-policies :get get-policy :update update-policy :delete delete-policy}
   "sensors" {:create create-sensor :list list-sensors :get get-sensor :update update-sensor :delete delete-sensor}
   "trajectories" {:create create-trajectory :list list-trajectories :get get-trajectory :update update-trajectory :delete delete-trajectory}})

(defn- expand-opts [params]
  (when-let [x (:expand params)]
    {:expand (set (map keyword (str/split (str x) #",")))}))

(defn dispatch
  "Route an HTTP-ish request through `routes` to the CRUD fns.
   req: {:method (:get/:post/:patch/:delete) :path /v1/<coll>[/<id>] :params {} :body {}}.
   Returns {:status int :body any} — the runnable L4 service surface."
  [port {:keys [method path params body]}]
  (let [segs (->> (str/split (or path "") #"/") (remove str/blank?) vec)
        coll (get segs 1)
        id   (get segs 2)
        h    (get handlers coll)
        params (or params {})]
    (cond
      (nil? h) {:status 404 :body {:error "unknown collection"}}
      (and (= method :post) (nil? id)) {:status 201 :body ((:create h) port (or body params))}
      (and (= method :get) (nil? id)) {:status 200 :body ((:list h) port params)}
      (and (= method :get) id) (if-let [r ((:get h) port id (expand-opts params))]
                                 {:status 200 :body r} {:status 404 :body {:error "not found"}})
      (and (#{:patch :put} method) id) (if-let [r ((:update h) port id (or body params))]
                                         {:status 200 :body r} {:status 404 :body {:error "not found"}})
      (and (= method :delete) id) {:status 200 :body ((:delete h) port id)}
      :else {:status 405 :body {:error "method not allowed"}})))

(defn healthz []
  {:status "ok" :actor "nvidia_isaac-compat" :tier "L4"
   :lang "clojure" :persistence "datomic-eavt-kotoba"
   :entities entities})
