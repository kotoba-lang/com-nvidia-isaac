                   (conj [:db/add id :nvidia_isaac.Sensor/updatedAt (now)]))]
      (-transact port sets)
      (-pull port id))))

(defn delete-sensor
  "Delete a Sensor."
  [port id]
  (-transact port [[:db/retractEntity id]])
  {:id id :deleted true})

;; ── Trajectory ────────────────────────────────────────────────────────────────
(defn create-trajectory
  "Create a Trajectory."
  [port data]
  (require-fields data ["waypoints" "durationS"])
  (let [id (new-id "isaac_tra")
        e {:db/id id
           :nvidia_isaac.Trajectory/id id
           :nvidia_isaac.Trajectory/robotId (get data :robotId)
           :nvidia_isaac.Trajectory/waypoints (as-long (get data :waypoints))
           :nvidia_isaac.Trajectory/durationS (as-double (get data :durationS))
           :nvidia_isaac.Trajectory/status (get data :status)
           :nvidia_isaac.Trajectory/createdAt (now)
           :nvidia_isaac.Trajectory/updatedAt (now)}]
    (-transact port [e])
    e))

(defn list-trajectories
  "List Trajectory with optional filtering + cursor pagination → L4 list map.
   opts: {:filter {<attr-kw> v} :limit N :starting-after <db/id>}."
  ([port] (list-trajectories port {}))
  ([port opts]
   (let [rows (mapv (fn [e] (-pull port e)) (-find-by-attr port :nvidia_isaac.Trajectory/id))
         rows (apply-filters rows (:filter opts) [:nvidia_isaac.Trajectory/robotId :nvidia_isaac.Trajectory/waypoints :nvidia_isaac.Trajectory/durationS :nvidia_isaac.Trajectory/status])]
     (paginate rows opts))))

(defn get-trajectory
  "Retrieve a Trajectory by id; opts {:expand #{:field}} inlines referenced entities. nil if absent."
  ([port id] (get-trajectory port id nil))
  ([port id opts]
   (when-let [rec (-pull port id)]
     (let [want (:expand opts)]
       (cond-> rec)))))

(defn update-trajectory
  "Update a Trajectory; returns the new entity map, or nil if absent."
  [port id data]
  (when (-pull port id)
    (let [sets (-> []
                   (cond-> (contains? data :robotId) (conj [:db/add id :nvidia_isaac.Trajectory/robotId (get data :robotId)]))
                   (cond-> (contains? data :waypoints) (conj [:db/add id :nvidia_isaac.Trajectory/waypoints (as-long (get data :waypoints))]))
                   (cond-> (contains? data :durationS) (conj [:db/add id :nvidia_isaac.Trajectory/durationS (as-double (get data :durationS))]))
                   (cond-> (contains? data :status) (conj [:db/add id :nvidia_isaac.Trajectory/status (get data :status)]))
                   (conj [:db/add id :nvidia_isaac.Trajectory/updatedAt (now)]))]
      (-transact port sets)
      (-pull port id))))

(defn delete-trajectory
  "Delete a Trajectory."
  [port id]
  (-transact port [[:db/retractEntity id]])
  {:id id :deleted true})

